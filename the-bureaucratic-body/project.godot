; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Bureaucratic Body"
run/main_scene="uid://cpfs1qy2pyce5"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
Global="*res://Scripts/global.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=768

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[internationalization]

locale/translations_pot_files=PackedStringArray("res://dialogue/wake_up.dialogue", "res://dialogue/burbody_dialogue/scene1_wakeup.dialogue", "res://dialogue/burbody_dialogue/scene2_outfit_reason.dialogue", "res://dialogue/burbody_dialogue/scene3_closet.dialogue", "res://dialogue/burbody_dialogue/scene4_eavesdrop.dialogue", "res://dialogue/burbody_dialogue/scene5_presentation.dialogue", "res://dialogue/burbody_dialogue/scene6_meeting.dialogue")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
